@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using GuildArena.Web.Security
@inject AuthenticationStateProvider AuthState
@inject HttpClient Http
@inject NavigationManager NavManager

<div class="page game-container">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main class="main-content">
        <!-- Top Row agora usa justify-content-between para empurrar extremos -->
        <div class="top-row px-4 auth d-flex justify-content-between align-items-center">
            <AuthorizeView>
                <Authorized>
                    <!-- ESQUERDA: Gold -->
                    @* <div class="gold-container d-flex align-items-center bg-dark px-3 py-1 rounded border border-warning">
                        <span class="text-warning fw-bold me-2">500</span>
                        <span title="Gold">🪙</span>
                    </div> *@

                    <!-- DIREITA: User e Logout -->
                    <div class="user-profile ms-auto d-flex align-items-center">
                        <span class="me-3 text-light fw-bold d-none d-sm-inline">@context.User.Identity?.Name</span>
                        <button class="btn btn-sm btn-outline-danger" @onclick="ExecuteLogout">Logout</button>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div></div> <!-- Espaçador invisível para empurrar o botão para a direita -->
                    <a href="/login" class="btn btn-warning fw-bold">Login to Play</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private async Task ExecuteLogout()
    {
        try
        {
            await Http.PostAsync("api/account/logout", null);
            var customAuthState = (CookieAuthenticationStateProvider)AuthState;
            customAuthState.NotifyAuthStatusChanged();
            NavManager.NavigateTo("/login");
        }
        catch { }
    }
}
@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using GuildArena.Web.Security
@using GuildArena.Web.State
@using GuildArena.Domain.Enums.Matches
@inject AuthenticationStateProvider AuthState
@inject HttpClient Http
@inject NavigationManager NavManager
@inject ICombatStateService CombatState

<div class="page game-container">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main class="main-content">
        <!-- Top Row usa justify-content-between para empurrar extremos -->
        <div class="top-row px-4 auth d-flex justify-content-between align-items-center">
            <AuthorizeView>

                <Authorizing>
                    <div class="ms-auto text-warning small fst-italic">Connecting to server...</div>
                </Authorizing>

                <Authorized>
                    <!-- DIREITA: User Account e Logout -->
                    <div class="user-profile ms-auto d-flex align-items-center gap-3">
                        <a href="/account" class="text-decoration-none d-flex align-items-center account-link" title="Manage Account">
                            <div class="avatar-circle me-2 d-flex justify-content-center align-items-center bg-dark border border-secondary">
                                <span class="fs-6">👤</span>
                            </div>
                            <span class="text-light fw-bold d-none d-sm-inline account-name">@context.User.Identity?.Name</span>
                        </a>
                        <button class="btn btn-sm btn-outline-danger fw-bold" @onclick="ExecuteLogout">Logout</button>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div></div> <!-- Espaçador invisível para empurrar o botão para a direita -->
                    <a href="/login" class="btn btn-warning fw-bold">Login to Play</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            // 1. Sempre que a SPA carrega (F5), perguntamos à API se há combate ativo.
            // (Isto só corre 1x no carregamento da página, não corre em navegação normal de menus)
            var activeCombat = await CombatState.CheckActiveCombatAsync();

            if (activeCombat != null && activeCombat.HasActiveCombat)
            {
                // 2. O Blazor perdeu a memória do combate (porque fizemos F5)?
                if (string.IsNullOrEmpty(CombatState.CombatId))
                {
                    // Descarrega o estado da API e liga o SignalR!
                    await CombatState.RejoinCombatAsync(activeCombat.CombatId!);
                }

                // 3. Ele tentou ir para outra página que não a Arena?
                if (!NavManager.Uri.Contains("/arena"))
                {
                    // Forçamos o regresso à arena!
                    NavManager.NavigateTo("/arena");
                }
            }
        }
    }


    private async Task ExecuteLogout()
    {
        try
        {
            await Http.PostAsync("api/account/logout", null);
            var customAuthState = (CookieAuthenticationStateProvider)AuthState;
            customAuthState.NotifyAuthStatusChanged();
            NavManager.NavigateTo("/login");
        }
        catch { }
    }
}
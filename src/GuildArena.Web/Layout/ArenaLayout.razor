@inherits LayoutComponentBase
@using GuildArena.Web.State
@inject ICombatStateService CombatState

<div class="arena-wrapper">
    <header class="arena-header d-flex justify-content-between align-items-center px-3">
        <div class="arena-brand text-warning fw-bold">
            GuildArena
        </div>
        <div class="arena-actions">
            <button class="btn btn-sm btn-outline-light me-2">Options</button>
            @if (!string.IsNullOrEmpty(CombatState.CombatId))
            {
                <button class="btn btn-sm btn-outline-danger" @onclick="SurrenderAsync">Surrender</button>
            }
        </div>
    </header>

    <main class="arena-main">
        @Body
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        CombatState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        CombatState.OnChange -= StateHasChanged;
    }

    private async Task SurrenderAsync()
    {
        await CombatState.SurrenderAsync();
    }
}
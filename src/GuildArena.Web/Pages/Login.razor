@page "/login"
@using GuildArena.Shared.Requests
@using GuildArena.Web.Security
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject AuthenticationStateProvider AuthState
@inject NavigationManager NavManager

<PageTitle>Login</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card bg-dark text-light border-secondary">
                <div class="card-header border-secondary text-center text-warning">
                    <h4>GuildArena Login</h4>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger p-2">@_errorMessage</div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control bg-secondary text-light" @bind="_request.Email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control bg-secondary text-light" @bind="_request.Password" />
                    </div>
                    <button class="btn btn-warning w-100 fw-bold" @onclick="ExecuteLogin" disabled="@_isLoading">
                        @(_isLoading ? "Connecting..." : "Login")
                    </button>

                    <div class="mt-4 text-center border-top border-secondary pt-3">
                        <p class="mb-1 text-muted">Don't have a Guild yet?</p>
                        <a href="/register" class="btn btn-outline-info w-100">Create Account</a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginRequest _request = new() { Email = string.Empty, Password = string.Empty };
    private string? _errorMessage;
    private bool _isLoading;

    protected override void OnInitialized()
    {
        // Preenche com os dados do seeder para facilitar testes durante o desenvolvimento
        _request.Email = "dev@guildarena.com";
        _request.Password = "Password123!";
    }

    private async Task ExecuteLogin()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("login?useCookies=true", _request);

            if (response.IsSuccessStatusCode)
            {
                var customAuthState = (CookieAuthenticationStateProvider)AuthState;
                customAuthState.NotifyAuthStatusChanged();

                NavManager.NavigateTo("/guild");
            }
            else
            {
                _errorMessage = "Invalid login attempt.";
            }
        }
        catch
        {
            _errorMessage = "Connection error.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
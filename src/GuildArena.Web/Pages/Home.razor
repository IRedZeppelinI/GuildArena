@page "/"
@attribute [Authorize]
@using GuildArena.Shared.DTOs.GuildAndHeroes
@using GuildArena.Shared.Requests
@using GuildArena.Web.Security
@using GuildArena.Web.State
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject HttpClient Http
@inject ICombatStateService CombatService
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthState

<PageTitle>GuildArena - Home</PageTitle>

<div class="container mt-4 text-light">
    @if (_isCheckingState)
    {
        <p><em>Loading your profile...</em></p>
    }
    else if (!_hasGuild)
    {
        <!-- ECRÃ DE CRIAÇÃO DE GUILDA -->
        <div class="row justify-content-center mt-5">
            <div class="col-md-6">
                <div class="card bg-dark border-warning">
                    <div class="card-header text-center text-warning fw-bold">
                        Welcome to GuildArena!
                    </div>
                    <div class="card-body">
                        <p class="text-center">You don't have a Guild yet. Found one to receive your starter heroes!</p>

                        @if (!string.IsNullOrEmpty(_guildError))
                        {
                            <div class="alert alert-danger p-2">@_guildError</div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Guild Name</label>
                            <input type="text" class="form-control bg-secondary text-light" @bind="_guildName" placeholder="e.g. Knights of Cydonia" />
                        </div>
                        <button class="btn btn-warning w-100 fw-bold" @onclick="CreateGuildAsync" disabled="@_isCreatingGuild">
                            @(_isCreatingGuild ? "Forging Guild..." : "Create Guild")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- LOBBY / ROSTER (Como tínhamos antes) -->
        <h2 class="text-warning">Guild Roster</h2>
        <p>Select exactly 3 heroes to enter the Arena.</p>

        @if (_heroes == null)
        {
            <p><em>Loading roster...</em></p>
        }
        else
        {
            <div class="row">
                @foreach (var hero in _heroes)
                {
                    var isSelected = _selectedHeroIds.Contains(hero.Id);
                    <div class="col-md-4 mb-3">
                        <div class="card @(isSelected ? "border-warning" : "border-secondary") bg-dark text-center"
                             style="cursor: pointer;"
                             @onclick="() => ToggleSelection(hero.Id)">
                            <div class="card-body">
                                <h5 class="card-title text-info">@hero.DefinitionId</h5>
                                <p class="card-text small text-muted">Level @hero.CurrentLevel | ID: @hero.Id</p>
                                @if (isSelected)
                                {
                                    <span class="badge bg-warning text-dark">Selected</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="text-center mt-4 border-top border-secondary pt-3">
                <h4>Selected: @_selectedHeroIds.Count / 3</h4>
                <button class="btn btn-danger btn-lg mt-2 fw-bold"
                        disabled="@(_selectedHeroIds.Count != 3 || CombatService.IsConnecting)"
                        @onclick="StartMatchAsync">
                    @(CombatService.IsConnecting ? "Entering Arena..." : "ENTER ARENA")
                </button>
            </div>
        }
    }
</div>

@code {
    // Estado do Utilizador
    private bool _isCheckingState = true;
    private bool _hasGuild = false;

    // Estado da Criação de Guilda
    private string _guildName = string.Empty;
    private bool _isCreatingGuild;
    private string? _guildError;

    // Estado do Lobby
    private List<HeroDto>? _heroes;
    private List<int> _selectedHeroIds = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;

        // Verifica se o Claim "GuildId" existe no cookie
        _hasGuild = user.HasClaim(c => c.Type == "GuildId");
        _isCheckingState = false;

        if (_hasGuild)
        {
            await LoadRosterAsync();
        }
    }

    private async Task CreateGuildAsync()
    {
        _isCreatingGuild = true;
        _guildError = null;

        try
        {
            var request = new CreateGuildRequest { GuildName = _guildName };
            var response = await Http.PostAsJsonAsync("api/guild/create", request);

            if (response.IsSuccessStatusCode)
            {
                // A API atualizou o Cookie. Temos de dizer ao Blazor para ir ler o perfil de novo!
                var customAuthState = (CookieAuthenticationStateProvider)AuthState;
                customAuthState.NotifyAuthStatusChanged();

                // Força o recarregamento da página para entrar no Lobby
                NavManager.NavigateTo("/", forceLoad: true);
            }
            else
            {
                _guildError = "Failed to create guild. Please try a different name.";
            }
        }
        catch
        {
            _guildError = "Connection error.";
        }
        finally
        {
            _isCreatingGuild = false;
        }
    }

    private async Task LoadRosterAsync()
    {
        try
        {
            _heroes = await Http.GetFromJsonAsync<List<HeroDto>>("api/guild/my-roster");
        }
        catch
        {
            // Placeholder error handling
        }
    }

    private void ToggleSelection(int heroId)
    {
        if (_selectedHeroIds.Contains(heroId))
        {
            _selectedHeroIds.Remove(heroId);
        }
        else if (_selectedHeroIds.Count < 3)
        {
            _selectedHeroIds.Add(heroId);
        }
    }

    private async Task StartMatchAsync()
    {
        if (_selectedHeroIds.Count == 3)
        {
            //TODO, criar mecanismo para encounter diferentes
            await CombatService.StartPveCombatAsync("ENC_TUTORIAL_01", _selectedHeroIds);
            NavManager.NavigateTo("/arena");
        }
    }
}
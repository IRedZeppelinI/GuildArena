@page "/forgot-password"
@using GuildArena.Shared.Requests
@inject HttpClient Http

<PageTitle>Forgot Password</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card bg-dark text-light border-secondary shadow-lg">
                <div class="card-header border-secondary text-center text-warning">
                    <h4 class="mb-0 py-1" style="font-family: 'Cinzel', serif;">Recover Access</h4>
                </div>
                <div class="card-body p-4">

                    @if (_isSubmitted)
                    {
                        <div class="alert alert-success border-success text-center">
                            <h5 class="fw-bold mb-2">Request Processed</h5>
                            <p class="mb-0 small">If an account matches that email address, a password reset link has been dispatched to your inbox.</p>
                        </div>
                        <div class="text-center mt-4">
                            <a href="/login" class="btn btn-outline-warning w-100">Return to Login</a>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center mb-4">Enter your registered email address below, and we will send you a secure link to reset your password.</p>

                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="alert alert-danger p-2 border-danger shadow-sm small text-center">@_errorMessage</div>
                        }

                        <div class="mb-4">
                            <label class="form-label text-warning fw-bold">Account Email</label>
                            <input type="email" class="form-control bg-secondary text-light border-dark" @bind="_email" placeholder="champion@guildarena.com" />
                        </div>

                        <button class="btn btn-warning w-100 fw-bold py-2" @onclick="SubmitRequestAsync" disabled="@_isLoading">
                            @(_isLoading ? "Sending Raven..." : "Send Reset Link")
                        </button>

                        <div class="mt-4 text-center border-top border-secondary pt-3">
                            <a href="/login" class="text-muted text-decoration-none small">Remembered your password? Cancel.</a>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _email = string.Empty;
    private bool _isLoading;
    private bool _isSubmitted;
    private string? _errorMessage;

    private async Task SubmitRequestAsync()
    {
        if (string.IsNullOrWhiteSpace(_email))
        {
            _errorMessage = "Please enter a valid email address.";
            return;
        }

        _isLoading = true;
        _errorMessage = null;

        try
        {
            var request = new ForgotPasswordRequest { Email = _email };

            // O Identity API mapeia este endpoint para /forgotPassword
            var response = await Http.PostAsJsonAsync("forgotPassword", request);

            // Quer tenha sucesso ou não (ex: email não existe), mostramos a mesma mensagem
            // de sucesso para evitar "Email Enumeration Attacks" por motivos de segurança.
            _isSubmitted = true;
        }
        catch (Exception)
        {
            _errorMessage = "A network error occurred. Please try again later.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
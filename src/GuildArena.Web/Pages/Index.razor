@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@using GuildArena.Shared.DTOs.News
@inject AuthenticationStateProvider AuthState
@inject HttpClient Http

<PageTitle>GuildArena - The Ultimate Tactical RPG</PageTitle>

<div class="jumbotron text-center py-5 mb-5 rounded shadow landing-banner">
    <h1 class="display-3 text-warning fw-bold mb-3 landing-title">GuildArena</h1>
    <p class="lead text-light mb-4">Draft your heroes. Master the essence. Conquer the Arena.</p>

    <AuthorizeView>
        <Authorized>
            <a href="/guild" class="btn btn-warning btn-lg fw-bold px-5 py-3 shadow">Enter your Guild</a>
        </Authorized>
        <NotAuthorized>
            <a href="/login" class="btn btn-warning btn-lg fw-bold px-5 py-2 me-3 shadow">Play Now</a>
            <a href="/register" class="btn btn-outline-light btn-lg px-4 py-2">Create Account</a>
        </NotAuthorized>
    </AuthorizeView>
</div>

<div class="row">
    <div class="col-12 mb-4 d-flex justify-content-between align-items-center border-bottom border-secondary pb-2">
        <h2 class="m-0">Latest News</h2>
        <AuthorizeView Roles="Admin">
            <Authorized>
                <a href="/admin/news/create" class="btn btn-sm btn-outline-info">Post News</a>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (_isLoading)
    {
        <p class="text-muted"><em>Loading latest news...</em></p>
    }
    else if (_news == null || !_news.Any())
    {
        <p class="text-muted">No news available at the moment.</p>
    }
    else
    {
        @foreach (var article in _news)
        {
            <div class="col-md-6 mb-4">
                <div class="card bg-dark border-secondary h-100 shadow d-flex flex-column news-card">
                    @if (!string.IsNullOrEmpty(article.ImageUrl))
                    {
                        <div class="news-card-img" style="background-image: url('@article.ImageUrl');"></div>
                    }
                    <div class="card-body d-flex flex-column">
                        <h4 class="card-title text-info">@article.Title</h4>
                        <p class="card-text text-muted flex-grow-1">@article.Summary</p>
                        <a href="/news/@article.Id" class="btn btn-outline-warning mt-2 align-self-start">Read More</a>
                    </div>
                    <div class="card-footer border-secondary text-muted text-end">
                        <small>@article.CreatedAt.ToString("MMM d, yyyy")</small>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<NewsSummaryDto>? _news;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _news = await Http.GetFromJsonAsync<List<NewsSummaryDto>>("api/news?limit=4");
        }
        catch
        {
            // Silently fail on homepage
        }
        finally
        {
            _isLoading = false;
        }
    }
}
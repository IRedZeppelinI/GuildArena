@page "/reset-password"
@using GuildArena.Shared.Requests
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>Reset Password</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card bg-dark text-light border-warning shadow-lg">
                <div class="card-header border-secondary text-center text-warning">
                    <h4 class="mb-0 py-1" style="font-family: 'Cinzel', serif;">Forge New Password</h4>
                </div>
                <div class="card-body p-4">

                    @if (string.IsNullOrEmpty(Email) || string.IsNullOrEmpty(Code))
                    {
                        <div class="alert alert-danger text-center border-danger">
                            <h6 class="fw-bold mb-1">Invalid Link</h6>
                            <p class="small mb-0">The password reset link is invalid or incomplete. Please request a new one.</p>
                        </div>
                    }
                    else if (_isSuccess)
                    {
                        <div class="text-center py-4">
                            <h2 class="text-success mb-3">✅ Password Reforged!</h2>
                            <p class="text-light mb-4">Your new password has been set successfully.</p>
                            <a href="/login" class="btn btn-success w-100 fw-bold">Proceed to Login</a>
                        </div>
                    }
                    else
                    {
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="alert alert-danger p-3 shadow-sm border-danger">
                                <h6 class="fw-bold mb-1">Action Failed</h6>
                                <span class="small">@_errorMessage</span>
                            </div>
                        }

                        <p class="text-muted small text-center mb-4">Creating a new password for <strong class="text-light">@Email</strong>.</p>

                        <div class="mb-3">
                            <label class="form-label text-warning fw-bold">New Password</label>
                            <input type="password" class="form-control bg-secondary text-light border-dark" @bind="_newPassword" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-warning fw-bold">Confirm New Password</label>
                            <input type="password" class="form-control bg-secondary text-light border-dark" @bind="_confirmPassword" />
                        </div>

                        <button class="btn btn-warning w-100 fw-bold py-2 fs-5" @onclick="ExecuteResetAsync" disabled="@_isLoading">
                            @(_isLoading ? "Forging..." : "Confirm New Password")
                        </button>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    [SupplyParameterFromQuery]
    public string? Code { get; set; }

    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;

    private bool _isLoading;
    private bool _isSuccess;
    private string? _errorMessage;

    private async Task ExecuteResetAsync()
    {
        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            _errorMessage = "A new password is required.";
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            _errorMessage = "The passwords do not match.";
            return;
        }

        _isLoading = true;
        _errorMessage = null;

        try
        {
            var request = new ResetPasswordRequest
            {
                Email = Email!,
                ResetCode = Code!,
                NewPassword = _newPassword
            };

            // O Identity API mapeia para /resetPassword
            var response = await Http.PostAsJsonAsync("resetPassword", request);

            if (response.IsSuccessStatusCode)
            {
                _isSuccess = true;
            }
            else
            {
                // O link pode ter expirado ou a password não cumprir os requisitos de segurança.
                _errorMessage = "Failed to reset password. The link might have expired, or the password is not strong enough.";
            }
        }
        catch (Exception)
        {
            _errorMessage = "Connection error. The server might be unreachable.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
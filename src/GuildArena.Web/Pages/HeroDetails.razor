@page "/hero/{DefinitionId}"
@attribute [Authorize]
@using GuildArena.Shared.DTOs.GuildAndHeroes
@using GuildArena.Shared.DTOs.Combat
@using GuildArena.Web.Services
@inject HttpClient Http
@inject IAssetService AssetService
@inject NavigationManager NavManager

<PageTitle>Hero Details</PageTitle>

<div class="container mt-4 text-light pb-5">

    <button class="btn btn-outline-secondary mb-4" @onclick='() => NavManager.NavigateTo("/roster")'>
        ← Back to Roster
    </button>

    @if (_errorMessage != null)
    {
        <div class="alert alert-danger mt-3 shadow-sm border-danger">
            <h5 class="text-danger fw-bold">Error loading hero</h5>
            <p class="mb-0">@_errorMessage</p>
        </div>
    }
    else if (_hero == null)
    {
        <div class="text-center mt-5"><p><em>Loading Hero Records...</em></p></div>
    }
    else
    {
        <!-- BLOCO SUPERIOR: Retrato e Stats lado a lado -->
        <div class="row mb-5">

            <!-- ESQUERDA: Retrato (Mais estreito: ocupa 3 a 4 colunas dependendo do ecrã) -->
            <div class="col-lg-3 col-md-4 mb-4 mb-md-0">
                <div class="card bg-dark border-secondary shadow-lg hero-portrait-card">
                    <!-- A imagem adapta-se automaticamente à largura da coluna -->
                    <img src="@AssetService.GetPortraitUrl(_hero.DefinitionId)" class="card-img-top hero-details-img" alt="@_hero.Name" />
                    <div class="card-body text-center p-3">
                        <h3 class="card-title text-warning fw-bold mb-0">@_hero.Name</h3>
                        <p class="text-info small mb-0">@_hero.RaceName</p>
                        <span class="badge bg-secondary mt-2">Level @_hero.CurrentLevel</span>
                    </div>
                </div>
            </div>

            <!-- DIREITA: Stats (Ocupa o resto do espaço) -->
            <div class="col-lg-9 col-md-8">
                <h4 class="text-warning border-bottom border-secondary pb-2 mb-4">Combat Attributes</h4>

                <!-- Grelha responsiva de Stats -->
                <div class="row text-center">
                    @StatBox("❤️", "Max HP", _hero.MaxHP, "text-danger")
                    @StatBox("⚔️", "Attack", _hero.Attack, "text-light")
                    @StatBox("🛡️", "Defense", _hero.Defense, "text-secondary")
                    @StatBox("⚡", "Agility", _hero.Agility, "text-success")
                    @StatBox("🔮", "Magic", _hero.Magic, "text-info")
                    @StatBox("🧿", "Magic Def", _hero.MagicDefense, "text-primary")
                </div>
            </div>
        </div>

        <!-- BLOCO INFERIOR: Habilidades em largura total (Full Width) -->
        <div class="row">
            <div class="col-12">
                <h4 class="text-warning border-bottom border-secondary pb-2 mb-4">Known Abilities</h4>

                <!-- Usamos uma grelha para as habilidades não ficarem esticadas ao máximo num PC gigante -->
                <div class="row">
                    @foreach (var ability in _hero.Abilities)
                    {
                        <div class="col-xl-6 col-lg-12 mb-3">
                            <div class="card bg-dark border-secondary shadow-sm d-flex flex-row overflow-hidden h-100 ability-card">
                                <div class="ability-icon-col" style="background-image: url('@AssetService.GetAbilityIconUrl(ability.Id)');"></div>

                                <div class="card-body p-3 d-flex flex-column justify-content-between">
                                    <div>
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h5 class="text-info fw-bold mb-0">@ability.Name</h5>
                                            <div class="d-flex gap-2 text-muted small">
                                                <span>AP: @ability.ActionPointCost</span>
                                                <span>CD: @ability.BaseCooldown</span>
                                            </div>
                                        </div>

                                        <div class="mb-2">
                                            @if (ability.Tags != null)
                                            {
                                                @foreach (var tag in ability.Tags)
                                                {
                                                    <span class="badge bg-secondary me-1">@tag</span>
                                                }
                                            }
                                        </div>
                                        <p class="card-text text-light small mb-2">@ability.Description</p>
                                    </div>

                                    <div class="d-flex gap-3 mt-2 flex-wrap align-items-center">
                                        @if (ability.Costs != null && ability.Costs.Any())
                                        {
                                            @foreach (var cost in ability.Costs.Where(c => c.Value > 0))
                                            {
                                                <div class="d-flex align-items-center" title="@cost.Key Essence">
                                                    <span class="fw-bold text-light me-1">@cost.Value</span>
                                                    <span class="text-muted small me-2">x</span>
                                                    <div class="cost-essence-icon" style="background-image: url('@AssetService.GetEssenceIconUrl(cost.Key.ToString())');"></div>
                                                </div>
                                            }
                                        }
                                        @if (ability.HPCost > 0)
                                        {
                                            <div class="d-flex align-items-center" title="Health Points">
                                                <span class="fw-bold text-danger me-1">@ability.HPCost</span>
                                                <span class="text-muted small me-2">x</span>
                                                <div class="cost-hp-icon d-flex justify-content-center align-items-center">❤️</div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string DefinitionId { get; set; } = string.Empty;

    private HeroDetailsDto? _hero;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _hero = await Http.GetFromJsonAsync<HeroDetailsDto>($"api/character/{DefinitionId}");
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = $"API HTTP Error: {ex.StatusCode}. Controller missing or API needs restart.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unexpected Error: {ex.Message}";
        }
    }

    private RenderFragment StatBox(string icon, string name, int value, string colorClass) => __builder =>
    {
        <!-- Ajustado para ficar 2/linha em mobile, 3/linha em tablets, 6/linha em ecrãs grandes -->
        <div class="col-6 col-sm-4 col-lg-2 mb-3">
            <div class="p-3 bg-dark border border-secondary rounded shadow-sm h-100 d-flex flex-column justify-content-center align-items-center stat-box">
                <div class="fs-3 mb-1">@icon</div>
                <div class="text-muted mb-2 stat-box-title text-uppercase">@name</div>
                <div class="fw-bold fs-4 @colorClass">@value</div>
            </div>
        </div>
    };
}
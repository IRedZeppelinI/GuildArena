@page "/hero/{DefinitionId}"
@attribute [Authorize]
@using GuildArena.Shared.DTOs.GuildAndHeroes
@using GuildArena.Shared.DTOs.Combat
@using GuildArena.Domain.Enums.Stats
@using GuildArena.Domain.Enums.Combat
@using GuildArena.Web.Services
@inject HttpClient Http
@inject IAssetService AssetService
@inject NavigationManager NavManager

<PageTitle>Hero Details</PageTitle>

<div class="container mt-4 text-light pb-5">

    <button class="btn btn-outline-secondary mb-4" @onclick='() => NavManager.NavigateTo("/roster")'>
        ← Back to Roster
    </button>

    @if (_errorMessage != null)
    {
        <div class="alert alert-danger mt-3 shadow-sm border-danger">
            <h5 class="text-danger fw-bold">Error loading hero</h5><p class="mb-0">@_errorMessage</p>
        </div>
    }
    else if (_hero == null)
    {
        <div class="text-center mt-5"><p><em>Loading Hero Records...</em></p></div>
    }
    else
    {
        <!-- BLOCO SUPERIOR: Retrato (Esq) | Stats + Traits (Dir) -->
        <div class="row mb-5">

            <!-- COLUNA ESQUERDA: Retrato -->
            <div class="col-lg-3 col-md-4 mb-4 mb-md-0">
                <div class="card bg-dark border-secondary shadow-lg hero-portrait-card">
                    <img src="@AssetService.GetPortraitUrl(_hero.DefinitionId)" class="card-img-top hero-details-img" alt="@_hero.Name" />
                    <div class="card-body text-center p-3 border-bottom border-secondary">
                        <h3 class="card-title text-warning fw-bold mb-0">@_hero.Name</h3>
                        <p class="text-info small mb-2">@_hero.RaceName</p>
                        
                        <!-- HP e AP -->
                        <div class="d-flex justify-content-center gap-2 mt-2">
                            <span class="badge bg-danger fs-6 border border-secondary" title="Max Health Points">❤️ @_hero.MaxHP</span>
                            <span class="badge bg-warning text-dark fs-6 border border-secondary" title="Action Points">⚡ @_hero.MaxActions</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- COLUNA DIREITA: Stats no topo, Traits a preencher o espaço -->
            <div class="col-lg-9 col-md-8 d-flex flex-column">

                <!-- PARTE DE CIMA: STATS -->
                <div>
                    <h4 class="text-warning border-bottom border-secondary pb-2 mb-4">Combat Attributes</h4>
                    <div class="row text-center justify-content-center mb-4">
                        @StatBox("⚔️", "Attack", _hero.Attack, "text-light")
                        @StatBox("🛡️", "Defense", _hero.Defense, "text-secondary")
                        @StatBox("💨", "Agility", _hero.Agility, "text-success")
                        @StatBox("🔮", "Magic", _hero.Magic, "text-info")
                        @StatBox("🧿", "Magic Def", _hero.MagicDefense, "text-primary")
                    </div>
                </div>

                <!-- PARTE DE BAIXO: TRAITS PASSIVOS (Empilhados Verticalmente) -->
                @if (_hero.Traits.Any())
                {
                    <div class="mt-2 d-flex flex-column flex-grow-1">
                        <h4 class="text-warning border-bottom border-secondary pb-2 mb-3">Passive Traits</h4>

                        <div class="d-flex flex-column gap-3 align-items-stretch">
                            @foreach (var trait in _hero.Traits)
                            {
                                <div class="p-3 bg-black border border-secondary rounded shadow-sm">
                                    <h6 class="fw-bold mb-2">
                                        <span class="@(trait.IsRacial ? "text-success" : "text-warning")">@trait.SourceName Trait</span>
                                        <span class="text-light"> - </span>
                                        <span class="text-info">@trait.Name</span>
                                    </h6>
                                    @* <p class="text-light small mb-0 trait-desc">@trait.Description</p> *@
                                    <!-- O HTML mastiga a lista que o Backend lhe deu! -->
                                    <div class="text-light small mb-0">
                                        @foreach(var line in trait.DescriptionLines)
                                        {
                                            @if (string.IsNullOrEmpty(line))
                                            {
                                                <br />
                                            }
                                            else
                                            {
                                                @line <br />
                                            }
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- BLOCO INFERIOR: Habilidades (Full Width) -->
        <div class="row">
            <div class="col-12">
                <h4 class="text-warning border-bottom border-secondary pb-2 mb-4">Known Abilities</h4>

                <div class="row">
                    @foreach (var ability in _hero.Abilities)
                    {
                        <div class="col-xl-6 col-lg-12 mb-3">
                            <div class="card bg-dark border-secondary shadow-sm d-flex flex-row overflow-hidden h-100 ability-card">
                                <!-- A imagem de fundo tem mesmo de ser inline style -->
                                <div class="ability-icon-col" style="background-image: url('@AssetService.GetAbilityIconUrl(ability.Id)');"></div>

                                <div class="card-body p-3 d-flex flex-column justify-content-between w-100">
                                    <div>
                                        <!-- TOPO: Nome da Habilidade e Badges de AP/CD bem visíveis -->
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h5 class="text-info fw-bold mb-0">@ability.Name</h5>
                                            <div class="d-flex gap-2">
                                                <span class="badge bg-secondary border border-dark" title="Action Point Cost">⚡ @ability.ActionPointCost AP</span>
                                                <span class="badge bg-secondary border border-dark" title="Base Cooldown">⏳ @ability.BaseCooldown CD</span>
                                            </div>
                                        </div>
                                        
                                        <div class="mb-2">
                                            @if(ability.Tags != null)
                                            {
                                                foreach(var tag in ability.Tags) { <span class="badge bg-secondary me-1">@tag</span> }
                                            }
                                        </div>
                                        <p class="card-text text-light small mb-2">@ability.Description</p>

                                        <!-- MATEMÁTICA E MODIFICADORES (Com a duração dinâmica!) -->
                                        @if(ability.Effects != null && ability.Effects.Any())
                                        {
                                            <div class="effect-math-box p-2 mb-2 rounded border border-secondary">
                                                @foreach(var eff in ability.Effects)
                                                {
                                                    @if (eff.Type == EffectType.DAMAGE || eff.Type == EffectType.HEAL)
                                                    {
                                                        var isHeal = eff.Type == EffectType.HEAL;
                                                        var colorClass = isHeal ? "text-success" : "text-danger";
                                                        var actionText = isHeal ? "Healing" : "Damage";

                                                        <div class="d-flex justify-content-between align-items-center mb-1 effect-row">
                                                            <span>
                                                                <span class="@colorClass fw-bold fs-6">@eff.PredictedValue</span> 
                                                                <span class="text-light">@actionText</span>
                                                            </span>
                                                            <span class="effect-text-secondary">
                                                                (Base @eff.BaseAmount + @((int)Math.Round(eff.ScalingFactor * 100))% @eff.ScalingStat)
                                                            </span>
                                                        </div>
                                                    }
                                                    else if (eff.Type == EffectType.APPLY_MODIFIER && !string.IsNullOrEmpty(eff.ModifierName))
                                                    {
                                                        <div class="d-flex flex-column mb-1 effect-row">
                                                            <div class="d-flex justify-content-between align-items-center">
                                                                <span class="text-warning fw-bold">🛡️ Applies @eff.ModifierName</span>
                                                                @if (eff.DurationInTurns == -1)
                                                                {
                                                                    <span class="text-info small fw-bold">Permanent</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="text-info small fw-bold">@eff.DurationInTurns Turn@(eff.DurationInTurns > 1 ? "s" : "")</span>
                                                                }
                                                            </div>
                                                            <span class="effect-text-secondary">@eff.ModifierDescription</span>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>
                                    
                                    <!-- CUSTOS (Essence e HP) -->
                                    <div class="d-flex gap-3 mt-2 flex-wrap align-items-center">
                                        @if (ability.Costs != null)
                                        {
                                            foreach(var cost in ability.Costs.Where(c => c.Value > 0))
                                            {
                                                <div class="d-flex align-items-center" title="@cost.Key Essence">
                                                    <span class="fw-bold text-light me-1">@cost.Value</span><span class="text-muted small me-2">x</span>
                                                    <div class="cost-essence-icon" style="background-image: url('@AssetService.GetEssenceIconUrl(cost.Key.ToString())');"></div>
                                                </div>
                                            }
                                        }
                                        @if (ability.HPCost > 0)
                                        {
                                            <div class="d-flex align-items-center" title="Health Points">
                                                <span class="fw-bold text-danger me-1">@ability.HPCost</span>
                                                <span class="text-muted small me-2">x</span>
                                                <div class="cost-hp-icon d-flex justify-content-center align-items-center">❤️</div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string DefinitionId { get; set; } = string.Empty;

    private HeroDetailsDto? _hero;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try { _hero = await Http.GetFromJsonAsync<HeroDetailsDto>($"api/character/{DefinitionId}"); }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    private RenderFragment StatBox(string icon, string name, int value, string colorClass) => __builder =>
    {
        <div class="col-6 col-sm-4 col-lg-2 mb-3">
            <div class="p-3 bg-dark border border-secondary rounded shadow-sm h-100 d-flex flex-column justify-content-center align-items-center stat-box" title="@name">
                <div class="fs-3 mb-1">@icon</div>
                <div class="text-muted mb-2 stat-box-title text-uppercase">@name</div>
                <div class="fw-bold fs-4 @colorClass">@value</div>
            </div>
        </div>
    };
}
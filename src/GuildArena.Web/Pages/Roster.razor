@page "/roster"
@attribute [Authorize]
@using GuildArena.Shared.Requests
@using GuildArena.Web.Security
@using System.Security.Claims
@inject HttpClient Http
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthState
@inject IAssetService AssetService

<PageTitle>GuildArena - Roster</PageTitle>

<div class="container mt-4 text-light">
    @if (_isCheckingState)
    {
        <p><em>Loading your profile...</em></p>
    }
    else if (!_hasGuild)
    {
        <!-- Ecrã de criação de guilda -->
        <div class="row justify-content-center mt-5">
            <div class="col-md-6">
                <div class="card bg-dark border-warning shadow-lg">
                    <div class="card-header text-center text-warning fw-bold">Welcome to GuildArena!</div>
                    <div class="card-body">
                        <p class="text-center">You don't have a Guild yet. Found one to receive your starter heroes!</p>
                        @if (!string.IsNullOrEmpty(_guildError))
                        {
                            <div class="alert alert-danger p-2">@_guildError</div>
                        }
                        <div class="mb-3">
                            <label class="form-label">Guild Name</label>
                            <input type="text" class="form-control bg-secondary text-light" @bind="_guildName" placeholder="e.g. Knights of Cydonia" />
                        </div>
                        <button class="btn btn-warning w-100 fw-bold" @onclick="CreateGuildAsync" disabled="@_isCreatingGuild">
                            @(_isCreatingGuild ? "Forging Guild..." : "Create Guild")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- A GALERIA DE HERÓIS -->
        <div class="page-header">
            <h2 class="title text-warning">🏕️ Guild Roster</h2>
            <p class="subtitle">Manage your collected heroes, view their stats, and upgrade them.</p>
        </div>

        @if (_heroes == null)
        {
            <p class="text-center"><em>Loading roster...</em></p>
        }
        else
        {
            <div class="row mt-4">
                @foreach (var hero in _heroes)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                        <!-- Transformámos a <div> do cartão numa tag <a> -->
                        <a href="/hero/@hero.DefinitionId" class="card hero-card bg-dark border-secondary h-100 shadow text-decoration-none">
                            <div class="card-img-top hero-portrait"
                                 style="background-image: url('@AssetService.GetPortraitUrl(hero.DefinitionId)');">
                            </div>
                            <div class="card-body text-center">
                                <h5 class="card-title text-info fw-bold mb-1">@hero.Name</h5>
                                <p class="card-text small text-muted">Level @hero.CurrentLevel</p>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private bool _isCheckingState = true;
    private bool _hasGuild = false;
    private string _guildName = string.Empty;
    private bool _isCreatingGuild;
    private string? _guildError;
    private List<HeroDto>? _heroes;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;
        _hasGuild = user.HasClaim(c => c.Type == "GuildId");
        _isCheckingState = false;

        if (_hasGuild)
        {
            await LoadRosterAsync();
        }
    }

    private async Task CreateGuildAsync()
    {
        _isCreatingGuild = true;
        _guildError = null;
        try
        {
            var request = new CreateGuildRequest { GuildName = _guildName };
            var response = await Http.PostAsJsonAsync("api/guild/create", request);
            if (response.IsSuccessStatusCode)
            {
                var customAuthState = (CookieAuthenticationStateProvider)AuthState;
                customAuthState.NotifyAuthStatusChanged();
                NavManager.NavigateTo("/roster", forceLoad: true);
            }
            else
            {
                _guildError = "Failed to create guild. Please try a different name.";
            }
        }
        catch { _guildError = "Connection error."; }
        finally { _isCreatingGuild = false; }
    }

    private async Task LoadRosterAsync()
    {
        try { _heroes = await Http.GetFromJsonAsync<List<HeroDto>>("api/guild/my-roster"); }
        catch { }
    }

    private void InspectHero(int heroId)
    {
        NavManager.NavigateTo($"/hero/{heroId}");
    }
}
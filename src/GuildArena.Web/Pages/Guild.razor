@page "/guild"
@attribute [Authorize]
@using GuildArena.Shared.Requests
@using GuildArena.Shared.DTOs.GuildAndHeroes
@using GuildArena.Web.Security
@using System.Security.Claims
@inject HttpClient Http
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthState
@inject GuildArena.Web.Services.IAssetService AssetService

<PageTitle>Guild Profile</PageTitle>

<div class="container mt-4 text-light pb-5">
    @if (_isCheckingState)
    {
        <p><em>Loading your profile...</em></p>
    }
    else if (!_hasGuild)
    {
        <div class="row justify-content-center mt-5">
            <div class="col-md-6">
                <div class="card bg-dark border-warning shadow-lg">
                    <div class="card-header text-center text-warning fw-bold">Welcome to GuildArena!</div>
                    <div class="card-body">
                        <p class="text-center">You don't have a Guild yet. Found one to receive your starter heroes!</p>
                        @if (!string.IsNullOrEmpty(_guildError))
                        {
                            <div class="alert alert-danger p-2">@_guildError</div>
                        }
                        <div class="mb-3">
                            <label class="form-label">Guild Name</label>
                            <input type="text" class="form-control bg-secondary text-light" @bind="_guildName" placeholder="e.g. Knights of Cydonia" />
                        </div>
                        <button class="btn btn-warning w-100 fw-bold" @onclick="CreateGuildAsync" disabled="@_isCreatingGuild">
                            @(_isCreatingGuild ? "Forging Guild..." : "Create Guild")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- PAINEL DA GUILDA (Level, XP, W/L) -->
        @if (_profile != null)
        {
            <div class="card bg-dark border-warning mb-5 shadow-lg">
                <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-center">
                    <div class="mb-3 mb-md-0 text-center text-md-start">
                        <h2 class="text-warning fw-bold mb-0" style="font-family: 'Cinzel', serif;">@_profile.Name</h2>
                        <p class="text-info fw-bold mb-0">Level @_profile.Level</p>
                    </div>

                    <div class="text-center text-md-end">
                        <div class="mb-2" style="font-family: 'Cinzel', serif; font-size: 1.2rem;">
                            <span class="text-success fw-bold">@_profile.Wins W</span>
                            <span class="text-light mx-2">|</span>
                            <span class="text-danger fw-bold">@_profile.Losses L</span>
                        </div>

                        <div class="progress border border-secondary mb-1 xp-bar-container">
                            <!-- O inline style da width é a forma padrão do Bootstrap de preencher a barra de progresso -->
                            <div class="progress-bar bg-info" role="progressbar" style="width: @((_profile.CurrentXP * 100) / _profile.RequiredXP)%"></div>
                        </div>
                        <small class="text-light">@_profile.CurrentXP / @_profile.RequiredXP XP</small>
                    </div>
                </div>
            </div>
        }

        <!-- A GALERIA DE HERÓIS -->
        <div class="page-header">
            <h3 class="title text-light">🏕️ Collected Heroes</h3>
            <p class="subtitle">Manage your roster and view their attributes.</p>
        </div>

        @if (_heroes == null)
        {
            <p class="text-center"><em>Loading roster...</em></p>
        }
        else
        {
            <div class="row mt-4">
                @foreach (var hero in _heroes)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                        <a href="/hero/@hero.DefinitionId" class="card hero-card bg-dark border-secondary h-100 shadow text-decoration-none">
                            <div class="card-img-top hero-portrait" style="background-image: url('@AssetService.GetPortraitUrl(hero.DefinitionId)');"></div>
                            <div class="card-body text-center">
                                <h5 class="card-title text-info fw-bold mb-1">@hero.Name</h5>
                                <p class="card-text small text-muted">Level @hero.CurrentLevel</p>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private bool _isCheckingState = true;
    private bool _hasGuild = false;
    private string _guildName = string.Empty;
    private bool _isCreatingGuild;
    private string? _guildError;

    private GuildProfileDto? _profile;
    private List<HeroDto>? _heroes;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;
        _hasGuild = user.HasClaim(c => c.Type == "GuildId");
        _isCheckingState = false;

        if (_hasGuild)
        {
            await LoadGuildDataAsync();
        }
    }

    private async Task CreateGuildAsync()
    {
        _isCreatingGuild = true;
        _guildError = null;
        try
        {
            var request = new CreateGuildRequest { GuildName = _guildName };
            var response = await Http.PostAsJsonAsync("api/guild/create", request);
            if (response.IsSuccessStatusCode)
            {
                var customAuthState = (CookieAuthenticationStateProvider)AuthState;
                customAuthState.NotifyAuthStatusChanged();
                NavManager.NavigateTo("/guild", forceLoad: true);
            }
            else
            {
                _guildError = "Failed to create guild. Please try a different name.";
            }
        }
        catch { _guildError = "Connection error."; }
        finally { _isCreatingGuild = false; }
    }

    private async Task LoadGuildDataAsync()
    {
        try
        {
            // Dispara os dois pedidos ao mesmo tempo
            var profileTask = Http.GetFromJsonAsync<GuildProfileDto>("api/guild/profile");
            var rosterTask = Http.GetFromJsonAsync<List<HeroDto>>("api/guild/my-roster");

            await Task.WhenAll(profileTask, rosterTask);

            _profile = profileTask.Result;
            _heroes = rosterTask.Result;
        }
        catch { }
    }
}
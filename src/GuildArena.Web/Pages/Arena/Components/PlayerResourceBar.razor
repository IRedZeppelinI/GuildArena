@using GuildArena.Shared.DTOs.Combat

<div class="resource-bar">
    <div class="player-name">@Player.Name</div>

    <div class="d-flex align-items-center">
        <div class="essence-pool me-3">
            @foreach (var kvp in Player.EssencePool.Where(e => e.Value > 0))
            {
                <div class="essence-slot" title="@kvp.Key">
                    <div class="essence-icon @kvp.Key.ToString().ToLower()"></div>
                    <div class="essence-count">@kvp.Value</div>
                </div>
            }
        </div>

        @if (ShowExchangeButton)
        {
            <button class="btn btn-sm btn-outline-warning exchange-btn" @onclick="OnExchangeClicked" title="Exchange Essence (2 for 1)">
                ⇄
            </button>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public required CombatPlayerDto Player { get; set; }

    [Parameter]
    public bool ShowExchangeButton { get; set; } = false;

    [Parameter]
    public EventCallback OnExchangeClicked { get; set; }
}
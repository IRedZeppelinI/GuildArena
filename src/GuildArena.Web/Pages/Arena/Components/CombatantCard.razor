@using GuildArena.Shared.DTOs.Combat
@using GuildArena.Web.Services
@inject IAssetService AssetService

<div class="combatant-card @(Combatant.IsAlive ? "" : "dead") @(IsTargetingMode ? "targeting-mode" : "") @(IsValidTarget ? "valid-target" : "") @(IsSelectedTarget ? "selected-target" : "")"
     @onclick="OnCardClicked">

    <!-- COLUNA ESQUERDA: Retrato e Modifiers -->
    <div class="card-left">
        <!-- O URL é gerado dinamicamente usando o DefinitionId (ex: HERO_GARRET) -->
        <div class="portrait-placeholder" style="background-image: url('@AssetService.GetPortraitUrl(Combatant.DefinitionId)');">
        </div>

        <div class="modifiers-zone">
            @foreach (var mod in Combatant.ActiveModifiers)
            {
                <div class="modifier-icon placeholder" title="@mod.DefinitionId"></div>
            }
        </div>
    </div>

    <!-- COLUNA DIREITA: Info e Habilidades -->
    <div class="card-right">
        <div class="info-top">
            <div class="name">@Combatant.Name</div>
            <div class="hp-container">
                <div class="hp-fill" style="width: @(HpPercentage)%"></div>
                <span class="hp-text">@Combatant.CurrentHP / @Combatant.MaxHP</span>
            </div>
        </div>

        <div class="abilities-zone">
            @foreach (var ability in AllAbilities)
            {
                <AbilityButton Ability="ability" OnAbilityClicked="HandleAbilityClick" />
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public required CombatantDto Combatant { get; set; }

    [Parameter]
    public bool IsTargetingMode { get; set; } = false;

    [Parameter]
    public bool IsValidTarget { get; set; } = false;

    [Parameter]
    public bool IsSelectedTarget { get; set; } = false;

    [Parameter]
    public EventCallback<CombatantDto> OnCombatantClicked { get; set; }

    [Parameter]
    public EventCallback<(int SourceId, string AbilityId)> OnAbilityActivated { get; set; }

    private int HpPercentage => Combatant.MaxHP == 0 ? 0 : (int)Math.Clamp(((double)Combatant.CurrentHP / Combatant.MaxHP) * 100, 0, 100);

    private IEnumerable<AbilitySummaryDto> AllAbilities
    {
        get
        {
            if (Combatant.SpecialAbility != null) yield return Combatant.SpecialAbility;
            foreach (var ab in Combatant.Abilities) yield return ab;
        }
    }

    private async Task OnCardClicked()
    {
        if (IsTargetingMode && IsValidTarget && !IsSelectedTarget)
        {
            // Passa o objeto completo para a Arena o poder processar
            await OnCombatantClicked.InvokeAsync(Combatant);
        }
    }

    private async Task HandleAbilityClick(string abilityId)
    {
        await OnAbilityActivated.InvokeAsync((Combatant.Id, abilityId));
    }
}
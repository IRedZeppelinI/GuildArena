@using GuildArena.Shared.DTOs.Combat
@using GuildArena.Web.Services
@inject IAssetService AssetService

<div class="ability-slot @(IsOnCooldown ? "on-cooldown" : "") @(!Ability.IsAffordable ? "unaffordable" : "")"
     @onclick="OnClick"
     @onmouseenter="OnMouseEnter"     
     title="@Ability.Name">

    <div class="ability-icon" style="background-image: url('@AssetService.GetAbilityIconUrl(Ability.Id)');"></div>

    @if (IsOnCooldown)
    {
        <div class="cooldown-overlay">
            <span>@Ability.CurrentCooldownTurns</span>
        </div>
    }

    @if (Ability.Costs.Any())
    {
        <div class="ability-costs">
            @foreach (var cost in Ability.Costs.Where(c => c.Value > 0))
            {
                @for (int i = 0; i < cost.Value; i++)
                {
                    <div class="mini-essence"
                         style="background-image: url('@AssetService.GetEssenceIconUrl(cost.Key.ToString())');"
                         title="@cost.Key">
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public required AbilitySummaryDto Ability { get; set; }

    [Parameter] public EventCallback<string> OnAbilityClicked { get; set; }
    [Parameter] public EventCallback<AbilitySummaryDto> OnInspectStart { get; set; }

    private bool IsOnCooldown => Ability.CurrentCooldownTurns > 0;
    private bool CanCast => !IsOnCooldown && Ability.IsAffordable;

    private async Task OnClick()
    {
        if (CanCast)
        {
            await OnAbilityClicked.InvokeAsync(Ability.Id);
        }
    }

    private async Task OnMouseEnter()
    {
        await OnInspectStart.InvokeAsync(Ability);
    }
    
}
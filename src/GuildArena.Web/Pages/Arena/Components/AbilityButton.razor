@using GuildArena.Shared.DTOs.Combat

<!-- Adicionada a classe 'unaffordable' dinamicamente -->
<div class="ability-slot @(IsOnCooldown ? "on-cooldown" : "") @(!Ability.IsAffordable ? "unaffordable" : "")" @onclick="OnClick" title="@Ability.Name">

    <div class="ability-border"></div>
    <div class="ability-icon-placeholder">@Ability.Name.Substring(0, 1)</div>

    @if (IsOnCooldown)
    {
        <div class="cooldown-overlay">
            <span>@Ability.CurrentCooldownTurns</span>
        </div>
    }

    @if (Ability.Costs.Any())
    {
        <div class="ability-costs">
            @foreach (var cost in Ability.Costs.Where(c => c.Value > 0))
            {
                @for (int i = 0; i < cost.Value; i++)
                {
                    <div class="mini-essence @cost.Key.ToString().ToLower()" title="@cost.Key"></div>
                }
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public required AbilitySummaryDto Ability { get; set; }

    [Parameter]
    public EventCallback<string> OnAbilityClicked { get; set; }

    private bool IsOnCooldown => Ability.CurrentCooldownTurns > 0;

    // NOVO: Só pode castar se não estiver em cooldown E se puder pagar!
    private bool CanCast => !IsOnCooldown && Ability.IsAffordable;

    private async Task OnClick()
    {
        if (CanCast)
        {
            await OnAbilityClicked.InvokeAsync(Ability.Id);
        }
    }
}
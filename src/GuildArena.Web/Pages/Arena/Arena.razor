@page "/arena"
@layout GuildArena.Web.Layout.ArenaLayout
@using Microsoft.AspNetCore.SignalR.Client
@using GuildArena.Domain.Enums.Resources
@using GuildArena.Shared.Requests
@using GuildArena.Shared.Responses
@using GuildArena.Shared.DTOs.Combat
@using GuildArena.Web.Pages.Arena.Components
@using GuildArena.Web.Pages.Arena.State
@using GuildArena.Web.Services
@inject IAssetService AssetService
@inject HttpClient Http
@inject ILogger<Arena> Logger
@implements IAsyncDisposable

<PageTitle>Battle Arena</PageTitle>

@if (string.IsNullOrEmpty(_combatId))
{
    <div class="startup-screen">
        <div class="startup-box">
            <h3 class="text-warning">GuildArena</h3>
            <p class="text-light">Prepare for battle.</p>
            <button class="btn btn-danger btn-lg mt-3" @onclick="StartCombatAsync" disabled="@_isConnecting">
                @if (_isConnecting)
                {
                    <span>Entering Arena...</span>
                }
                else
                {

                    <span>Start Match</span>
                }
            </button>
        </div>
    </div>
}
else
{
    <!-- MODAL DE LOGS PARA MOBILE -->
    @if (_showMobileLogs)
    {
        <div class="mobile-logs-modal" @onclick="ToggleMobileLogs">
            <div class="mobile-logs-content" @onclick:stopPropagation="true">
                <div class="d-flex justify-content-between align-items-center border-bottom border-secondary pb-2 mb-2">
                    <h5 class="text-warning m-0">Battle Logs</h5>
                    <button class="btn btn-sm btn-outline-light" @onclick="ToggleMobileLogs">Close</button>
                </div>
                <div style="flex-grow: 1; overflow: hidden; position: relative;">
                    <BattleLogPanel Logs="_battleLogs" ContainerId="mobile-logs-container" />
                </div>
            </div>
        </div>
    }

    <!-- MODAL DE EXCHANGE (TRANSMUTAÇÃO) -->
    @if (_showExchangeModal)
    {
        var me = _gameState!.Players.First(p => p.PlayerId == LocalPlayerId);
        <ExchangeEssenceModal PlayerEssencePool="me.EssencePool"
                              OnConfirmExchange="ExecuteExchangeAsync"
                              OnCancel="() => _showExchangeModal = false" />
    }

    <!-- MODAL DE PAGAMENTO (CUSTOS NEUTROS) -->
    @if (_showPaymentModal && _availableEssenceForPayment != null)
    {
        <PaymentModal AvailableEssence="_availableEssenceForPayment"
                      RequiredAmount="_neutralCostPending"
                      OnConfirmPayment="ProcessManualPaymentAndExecute"
                      OnCancel="CancelPayment" />
    }



    <!-- O clique no fundo da arena cancela a mira (Targeting) -->
    <div class="arena-board" style="@GetBackgroundStyle()" @onclick="CancelTargeting">

        <!-- LADO ESQUERDO: Equipa do Jogador -->
        <div class="team-side player-team" @onclick:stopPropagation="true">
            @if (_gameState != null)
            {
                var me = _gameState.Players.FirstOrDefault(p => p.PlayerId == LocalPlayerId);
                if (me != null)
                {
                    <PlayerResourceBar Player="me"
                                       ShowExchangeButton="@(_gameState.CurrentPlayerId == LocalPlayerId)"
                                       OnExchangeClicked="() => _showExchangeModal = true" />
                }

                <div class="combatants-column">
                    @foreach (var hero in MyTeam)
                    {
                        <CombatantCard Combatant="hero"
                                       IsTargetingMode="_targetingState.IsActive"
                                       IsValidTarget="_targetingState.IsValidTarget(hero)"
                                       IsSelectedTarget="_targetingState.IsSelected(hero.Id)"
                                       OnAbilityActivated="StartTargeting"
                                       OnCombatantClicked="SelectTarget" />
                    }
                </div>
            }
        </div>

        <!-- CENTRO -->
        <div class="arena-center">
            @if (_gameState != null)
            {
                <div class="turn-indicator">
                    Turn @_gameState.CurrentTurnNumber
                </div>
            }
        </div>

        <!-- LADO DIREITO: Inimigos -->
        <div class="team-side enemy-team" @onclick:stopPropagation="true">
            @if (_gameState != null)
            {
                var enemyPlayer = _gameState.Players.FirstOrDefault(p => p.PlayerId != LocalPlayerId);
                if (enemyPlayer != null)
                {
                    <PlayerResourceBar Player="enemyPlayer" />
                }

                <div class="enemy-grid">
                    @foreach (var enemy in EnemyTeam)
                    {
                        <div class="@GetGridClass(enemy.Position)">
                            <CombatantCard Combatant="enemy"
                                           IsTargetingMode="_targetingState.IsActive"
                                           IsValidTarget="_targetingState.IsValidTarget(enemy)"
                                           IsSelectedTarget="_targetingState.IsSelected(enemy.Id)"
                                           OnAbilityActivated="StartTargeting"
                                           OnCombatantClicked="SelectTarget" />
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- RODAPÉ -->
    <div class="arena-footer">
        <div class="footer-section footer-left">
            <button class="btn btn-outline-info mobile-logs-btn text-nowrap" @onclick="ToggleMobileLogs">
                📜 BattleLogs
            </button>
        </div>

        <div class="footer-section footer-center">
            <div class="desktop-logs-wrapper w-100 h-100">
                <BattleLogPanel Logs="_battleLogs" ContainerId="desktop-logs-container" />
            </div>
            <div class="mobile-ticker">
                @(_battleLogs.LastOrDefault() ?? "Waiting for actions...")
            </div>
        </div>

        <div class="footer-section footer-right">
            @if (_gameState != null && _gameState.CurrentPlayerId == LocalPlayerId)
            {
                if (_targetingState.IsActive)
                {
                    <button class="btn btn-secondary btn-lg end-turn-btn" @onclick="CancelTargeting">
                        Cancel Action
                    </button>
                }
                else
                {
                    <button class="btn btn-danger btn-lg end-turn-btn" @onclick="EndTurnAsync">
                        End Turn
                    </button>
                }
            }
            else if (_gameState != null)
            {
                <button class="btn btn-secondary btn-lg end-turn-btn" disabled>
                    Enemy Turn...
                </button>
            }
        </div>
    </div>
}

@code {
    private string? _combatId;
    private HubConnection? _hubConnection;
    private GameStateDto? _gameState;
    private List<string> _battleLogs = new();

    private bool _isConnecting = false;
    private bool _showMobileLogs = false;
    private bool _showExchangeModal = false;

    // --- ESTADO DO PAYMENT MODAL ---
    private bool _showPaymentModal = false;
    private int _neutralCostPending = 0;
    private Dictionary<EssenceType, int>? _availableEssenceForPayment;

    // --- PROPRIEDADES COMPUTADAS ---
    private int LocalPlayerId => 1;

    private string GetBackgroundStyle()
    {
        if (_gameState == null || string.IsNullOrEmpty(_gameState.BackgroundId))
            return ""; // Retorna vazio, o CSS usa o #222 de fallback

        var bgUrl = AssetService.GetBackgroundUrl(_gameState.BackgroundId);
        return $"background-image: url('{bgUrl}');";
    }


    private IEnumerable<CombatantDto> MyTeam =>
        _gameState?.Combatants.Where(c => c.OwnerId == LocalPlayerId) ?? Array.Empty<CombatantDto>();

    private IEnumerable<CombatantDto> EnemyTeam =>
        _gameState?.Combatants.Where(c => c.OwnerId != LocalPlayerId) ?? Array.Empty<CombatantDto>();

    // --- MÁQUINA DE ESTADOS DO TARGETING E PAGAMENTO ---
    private TargetingStateManager _targetingState = new();

    private void StartTargeting((int SourceId, string AbilityId) payload)
    {
        if (_gameState?.CurrentPlayerId != LocalPlayerId) return;

        var source = _gameState.Combatants.FirstOrDefault(c => c.Id == payload.SourceId);
        var ability = source?.Abilities.FirstOrDefault(a => a.Id == payload.AbilityId) ?? source?.SpecialAbility;

        if (ability == null || !ability.IsAffordable) return;

        _targetingState.StartTargeting(payload.SourceId, ability);

        // Verifica se a habilidade requer seleção manual E se não é uma magia de Área (AoE)
        bool requiresManualClicks = ability.TargetingRules.Any(r =>
            r.Strategy == GuildArena.Domain.Enums.Targeting.TargetSelectionStrategy.Manual &&
            r.Type != GuildArena.Domain.Enums.Targeting.TargetType.All &&
            r.Type != GuildArena.Domain.Enums.Targeting.TargetType.AllEnemies &&
            r.Type != GuildArena.Domain.Enums.Targeting.TargetType.AllAllies &&
            r.Type != GuildArena.Domain.Enums.Targeting.TargetType.AllFriendlies);

        if (!requiresManualClicks)
        {
            // Se for AoE (ex: Ulti da Elysia) ou TargetType.Self, salta logo para o pagamento
            TransitionToPaymentOrExecute();
        }
    }

    private void SelectTarget(CombatantDto target)
    {
        if (_targetingState.TrySelectTarget(target, out bool allRulesSatisfied))
        {
            if (allRulesSatisfied)
            {
                TransitionToPaymentOrExecute();
            }
        }
    }

    private void CancelTargeting()
    {
        _targetingState.Cancel();
    }

    private void TransitionToPaymentOrExecute()
    {
        var ability = _targetingState.ActiveAbility!;
        int neutralCost = ability.Costs.ContainsKey(EssenceType.Neutral) ? ability.Costs[EssenceType.Neutral] : 0;

        if (neutralCost > 0)
        {
            _neutralCostPending = neutralCost;

            var me = _gameState!.Players.First(p => p.PlayerId == LocalPlayerId);
            _availableEssenceForPayment = new Dictionary<EssenceType, int>(me.EssencePool);

            foreach (var cost in ability.Costs.Where(c => c.Key != EssenceType.Neutral))
            {
                _availableEssenceForPayment[cost.Key] -= cost.Value;
            }

            _showPaymentModal = true;
        }
        else
        {
            var finalPayment = ability.Costs.ToDictionary(k => k.Key, v => v.Value);
            _ = ExecuteAbilityAsync(finalPayment);
        }
    }

    private void CancelPayment()
    {
        _showPaymentModal = false;
        _targetingState.Cancel();
    }

    private async Task ProcessManualPaymentAndExecute(List<EssenceType> neutralPaymentChoices)
    {
        _showPaymentModal = false;

        var finalPayment = _targetingState.ActiveAbility!.Costs
            .Where(c => c.Key != EssenceType.Neutral)
            .ToDictionary(k => k.Key, v => v.Value);

        foreach (var choice in neutralPaymentChoices)
        {
            if (!finalPayment.ContainsKey(choice)) finalPayment[choice] = 0;
            finalPayment[choice]++;
        }

        await ExecuteAbilityAsync(finalPayment);
    }

    private async Task ExecuteAbilityAsync(Dictionary<EssenceType, int> payment)
    {
        if (string.IsNullOrEmpty(_combatId) || !_targetingState.IsActive) return;

        var request = new ExecuteAbilityRequest
        {
            CombatId = _combatId,
            SourceId = _targetingState.SourceId!.Value,
            AbilityId = _targetingState.ActiveAbility!.Id,
            // FIX: Fazer uma cópia real do dicionário e das listas para que o Cancel não as apague!
            TargetSelections = _targetingState.SelectedTargets.ToDictionary(
                entry => entry.Key,
                entry => new List<int>(entry.Value)),
            Payment = payment
        };

        _targetingState.Cancel();
        StateHasChanged();

        try
        {
            var response = await Http.PostAsJsonAsync($"api/combat/{_combatId}/execute-ability", request);

            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                Logger.LogWarning("Ability execution failed. API returned {StatusCode}: {Error}", response.StatusCode, error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "An unexpected error occurred while attempting to execute the ability.");
        }
    }

    // --- HTTP E SIGNALR ---
    private void ToggleMobileLogs() => _showMobileLogs = !_showMobileLogs;

    private async Task StartCombatAsync()
    {
        _isConnecting = true;
        try
        {
            var request = new StartPveRequest
            {
                EncounterId = "ENC_TUTORIAL_01",
                HeroInstanceIds = new List<int> { 101, 103, 104 }
            };

            var response = await Http.PostAsJsonAsync("api/combat/start-pve", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<StartCombatResponse>();
                if (result != null)
                {
                    _combatId = result.CombatId;
                    _battleLogs.AddRange(result.InitialLogs);
                    _gameState = result.InitialState;

                    await ConnectToSignalRAsync(_combatId);
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Logger.LogWarning("Failed to start combat. API returned {StatusCode}: {Error}", response.StatusCode, error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "An unexpected error occurred while attempting to start the combat session.");
        }
        finally
        {
            _isConnecting = false;
            StateHasChanged();
        }
    }

    private async Task ConnectToSignalRAsync(string combatId)
    {
        var apiBaseUrl = Http.BaseAddress?.ToString() ?? "";

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(apiBaseUrl + "hubs/combat")
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<GameStateDto>("ReceiveGameStateUpdate", (state) =>
        {
            _gameState = state;
            StateHasChanged();
        });

        _hubConnection.On<List<string>>("ReceiveBattleLogs", async (logs) =>
        {
            _battleLogs.AddRange(logs);
            await InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
        await _hubConnection.InvokeAsync("JoinCombat", combatId);
    }

    private async Task EndTurnAsync()
    {
        if (string.IsNullOrEmpty(_combatId)) return;

        try
        {
            var response = await Http.PostAsync($"api/combat/{_combatId}/end-turn", null);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                Logger.LogWarning("End turn request failed. API returned {StatusCode}: {Error}", response.StatusCode, error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "An unexpected error occurred while attempting to end the turn.");
        }
    }

    private async Task ExecuteExchangeAsync((Dictionary<EssenceType, int> Spent, EssenceType Gained) payload)
    {
        if (string.IsNullOrEmpty(_combatId)) return;

        var request = new ExchangeEssenceRequest
        {
            CombatId = _combatId,
            EssenceToSpend = payload.Spent,
            EssenceToGain = payload.Gained
        };

        try
        {
            var response = await Http.PostAsJsonAsync($"api/combat/{_combatId}/exchange-essence", request);

            if (response.IsSuccessStatusCode)
            {
                _showExchangeModal = false;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Logger.LogWarning("Exchange request failed. API returned {StatusCode}: {Error}", response.StatusCode, error);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "An unexpected error occurred while attempting to exchange essence.");
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            if (!string.IsNullOrEmpty(_combatId)) await _hubConnection.InvokeAsync("LeaveCombat", _combatId);
            await _hubConnection.DisposeAsync();
        }
    }

    private string GetGridClass(int position)
    {
        return position switch
        {
            0 => "grid-front-top",
            1 => "grid-front-mid",
            2 => "grid-front-bot",
            3 => "grid-back-top",
            4 => "grid-back-mid",
            5 => "grid-back-bot",
            _ => "grid-back-mid"
        };
    }
}
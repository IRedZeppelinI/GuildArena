@page "/arena"
@layout GuildArena.Web.Layout.ArenaLayout
@using Microsoft.AspNetCore.SignalR.Client
@using GuildArena.Shared.Requests
@using GuildArena.Shared.Responses
@using GuildArena.Shared.DTOs.Combat
@using GuildArena.Web.Pages.Arena.Components <!-- NOVO -->
@inject HttpClient Http
@implements IAsyncDisposable

<PageTitle>Battle Arena</PageTitle>

@if (string.IsNullOrEmpty(_combatId))
{
    <!-- Centrado no ecrã para não parecer feio -->
    <div class="startup-screen">
        <div class="startup-box">
            <h3 class="text-warning">GuildArena</h3>
            <p class="text-light">Prepare for battle.</p>
            <button class="btn btn-danger btn-lg mt-3" @onclick="StartCombatAsync" disabled="@_isConnecting">
                @if (_isConnecting)
                {
                    <span>Entering Arena...</span>
                }
                else
                {

                    <span>Start Match</span>
                }
            </button>
        </div>
    </div>
}
else
{
    <div class="arena-board">
        <!-- LADO ESQUERDO: Equipa do Jogador -->
        <div class="team-side player-team">
            @if (_gameState != null)
            {
                var me = _gameState.Players.FirstOrDefault(p => p.PlayerId == 1);
                if (me != null)
                {
                    <PlayerResourceBar Player="me" />
                }

                <div class="combatants-column">
                    @foreach (var hero in _gameState.Combatants.Where(c => c.OwnerId == 1))
                    {
                        <CombatantCard Combatant="hero" />
                    }
                </div>
            }
        </div>

        <!-- CENTRO: Espaço vazio / Animações -->
        <div class="arena-center">
            @if (_gameState != null)
            {
                <div class="turn-indicator">
                    Turn @_gameState.CurrentTurnNumber
                </div>
            }
        </div>

        <!-- LADO DIREITO: Inimigos (Grid 2x3) -->
        <div class="team-side enemy-team">
            @if (_gameState != null)
            {
                var enemyPlayer = _gameState.Players.FirstOrDefault(p => p.PlayerId != 1);
                if (enemyPlayer != null)
                {
                    // A AI também tem Essence, mostramos para saber o que o boss pode castar!
                    <PlayerResourceBar Player="enemyPlayer" />
                }

                <div class="enemy-grid">
                    @foreach (var mob in _gameState.Combatants.Where(c => c.OwnerId != 1))
                    {
                        // O método GetGridClass converte o 'Position' para uma classe CSS
                        <div class="@GetGridClass(mob.Position)">
                            <CombatantCard Combatant="mob" />
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- FUNDO: BATTLE LOGS -->
    <div class="battle-logs-panel">
        <ul class="log-list">
            @foreach (var log in _battleLogs)
            {
                <li>@log</li>
            }
        </ul>
    </div>
}



@code {
    // === ESTADO DO COMPONENTE ===
    private string? _combatId;
    private HubConnection? _hubConnection;
    private GameStateDto? _gameState;
    private List<string> _battleLogs = new();

    private bool _isConnecting = false;
    private bool _isConnected => _hubConnection?.State == HubConnectionState.Connected;

    // === MÉTODOS ===

    // 1. Pedido HTTP para criar o combate
    private async Task StartCombatAsync()
    {
        _isConnecting = true;
        try
        {
            var request = new StartPveRequest
            {
                EncounterId = "ENC_TUTORIAL_01",
                HeroInstanceIds = new List<int> { 101 } // Garret (Hardcoded ID provisório do repositório)
            };

            // Fazemos o POST para a API
            var response = await Http.PostAsJsonAsync("api/combat/start-pve", request);

            if (response.IsSuccessStatusCode)
            {
                // Lemos a resposta com os Logs Iniciais
                var result = await response.Content.ReadFromJsonAsync<StartCombatResponse>();
                if (result != null)
                {
                    _combatId = result.CombatId;
                    _battleLogs.AddRange(result.InitialLogs);

                    // Inicia WebSockets!
                    await ConnectToSignalRAsync(_combatId);
                }
            }
            else
            {
                _battleLogs.Add($"HTTP Error: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            _battleLogs.Add($"Error: {ex.Message}");
        }
        finally
        {
            _isConnecting = false;
            // O Blazor atualiza o ecrã automaticamente em eventos de cliques,
            // mas StateHasChanged() garante o refresh.
            StateHasChanged();
        }
    }

    // 2. Estabelecer Ligação SignalR
    private async Task ConnectToSignalRAsync(string combatId)
    {
        // Constrói a ligação apontando para o URL base do HttpClient + a rota do Hub
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Http.BaseAddress + "hubs/combat")
            .WithAutomaticReconnect()
            .Build();

        // Subscrição: O que fazer quando o servidor enviar um GameState?
        _hubConnection.On<GameStateDto>("ReceiveGameStateUpdate", (state) =>
        {
            _gameState = state;
            StateHasChanged(); // Força o ecrã a atualizar
        });

        // Subscrição: O que fazer quando o servidor enviar novos Logs?
        _hubConnection.On<List<string>>("ReceiveBattleLogs", (logs) =>
        {
            _battleLogs.AddRange(logs);
            StateHasChanged();
        });

        try
        {
            await _hubConnection.StartAsync();
            // Avisar o Hub que queremos entrar no "Grupo" específico deste combate
            await _hubConnection.InvokeAsync("JoinCombat", combatId);
            _battleLogs.Add("--- SignalR Connected! Waiting for actions... ---");
        }
        catch (Exception ex)
        {
            _battleLogs.Add($"SignalR Connection Error: {ex.Message}");
        }
    }

    // 3. Limpeza de Memória (Destrutor)
    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            if (!string.IsNullOrEmpty(_combatId))
            {
                await _hubConnection.InvokeAsync("LeaveCombat", _combatId);
            }
            await _hubConnection.DisposeAsync();
        }
    }


    private string GetGridClass(int position)
    {
        // Grid 2x3. Coluna 1 = Frente, Coluna 2 = Trás.
        // Linhas 1, 2, 3 = Topo, Meio, Fundo.
        return position switch
        {
            0 => "grid-front-top",
            1 => "grid-front-mid",
            2 => "grid-front-bot",
            3 => "grid-back-top",
            4 => "grid-back-mid",
            5 => "grid-back-bot",
            _ => "grid-back-mid" // Default boss position
        };
    }
}
@page "/encounters"
@attribute [Authorize]
@using GuildArena.Shared.DTOs.GuildAndHeroes
@using GuildArena.Shared.DTOs.Encounters
@using GuildArena.Web.State
@inject HttpClient Http
@inject ICombatStateService CombatService
@inject NavigationManager NavManager

<PageTitle>World Encounters</PageTitle>

<div class="container mt-4 text-light pb-5">

    <div class="page-header">
        <h2 class="title text-danger">⚔️ Encounters</h2>
        <p class="subtitle">Select a bounty and prepare your team for combat.</p>
    </div>

    <!-- LISTA DE ENCOUNTERS (Dinâmica da API) -->
    @if (_availableEncounters == null || _guildProfile == null)
    {
        <p class="text-center"><em>Loading bounties...</em></p>
    }
    else
    {
        <div class="row mb-5">
            @foreach (var encounter in _availableEncounters)
            {
                var isEncounterSelected = _selectedEncounterId == encounter.Id;
                var isLocked = _guildProfile.Level < encounter.RequiredGuildLevel;

                <div class="col-md-6 mb-3">
                    <div class="card encounter-card @(isLocked ? "encounter-locked" : (isEncounterSelected ? "border-danger shadow-lg" : "border-secondary")) bg-dark"
                         @onclick="() => { if (!isLocked) SelectEncounter(encounter.Id); }">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h4 class="text-warning mb-1">@encounter.Name</h4>
                                    <div class="text-light small mb-2">
                                        Difficulty:
                                        @for (int i = 0; i < encounter.DifficultyRating; i++)
                                        {
                                            <span class="text-warning">★</span>
                                        }
                                    </div>
                                </div>
                                @if (isLocked)
                                {
                                    <span class="badge bg-secondary border border-light">🔒 Requires Lv @encounter.RequiredGuildLevel</span>
                                }
                                else if (isEncounterSelected)
                                {
                                    <span class="badge bg-danger">Selected</span>
                                }
                            </div>
                            <p class="card-text text-light small mb-0">@encounter.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- SECÇÃO DE PREPARAÇÃO DE EQUIPA -->
    <div class="page-header">
        <h4 class="title text-info">Draft Your Team</h4>
        <p class="subtitle">Select exactly 3 heroes to enter the Arena.</p>
    </div>

    @if (_heroes == null)
    {
        <p class="text-center"><em>Loading your roster...</em></p>
    }
    else
    {
        <div class="row">
            @foreach (var hero in _heroes)
            {
                var isHeroSelected = _selectedHeroIds.Contains(hero.Id);
                <div class="col-md-3 col-sm-6 mb-3">
                    <div class="card hero-select-card @(isHeroSelected ? "border-warning shadow" : "border-secondary") bg-dark text-center h-100"
                         @onclick="() => ToggleHeroSelection(hero.Id)">
                        <div class="card-body p-2">
                            <h6 class="card-title text-info mb-1">@hero.Name</h6>
                            <p class="card-text small text-light mb-0">Level @hero.CurrentLevel</p>
                            @if (isHeroSelected)
                            {
                                <span class="badge bg-warning text-dark mt-2">Ready</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Barra Inferior de Ação -->
        <div class="text-center mt-4 border-top border-secondary pt-3">
            <h5 class="text-light mb-3">Team Size: <span class="text-warning">@_selectedHeroIds.Count</span> / 3</h5>
            <button class="btn btn-danger btn-lg fw-bold px-5"
                    disabled="@(!CanStartMatch)"
                    @onclick="StartMatchAsync">
                @(CombatService.IsConnecting ? "Entering Arena..." : "FIGHT!")
            </button>
        </div>
    }
</div>

@code {
    private List<EncounterSummaryDto>? _availableEncounters;
    private List<HeroDto>? _heroes;
    private GuildProfileDto? _guildProfile;

    private string? _selectedEncounterId;
    private List<int> _selectedHeroIds = new();

    private bool CanStartMatch => !string.IsNullOrEmpty(_selectedEncounterId)
                               && _selectedHeroIds.Count == 3
                               && !CombatService.IsConnecting;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var fetchEncountersTask = Http.GetFromJsonAsync<List<EncounterSummaryDto>>("api/encounter");
            var fetchHeroesTask = Http.GetFromJsonAsync<List<HeroDto>>("api/guild/my-roster");
            var fetchProfileTask = Http.GetFromJsonAsync<GuildProfileDto>("api/guild/profile"); // Pedido Novo

            await Task.WhenAll(fetchEncountersTask, fetchHeroesTask, fetchProfileTask);

            _availableEncounters = fetchEncountersTask.Result;
            _heroes = fetchHeroesTask.Result;
            _guildProfile = fetchProfileTask.Result;
        }
        catch { }
    }

    private void SelectEncounter(string encounterId)
    {
        _selectedEncounterId = encounterId;
    }

    private void ToggleHeroSelection(int heroId)
    {
        if (_selectedHeroIds.Contains(heroId))
            _selectedHeroIds.Remove(heroId);
        else if (_selectedHeroIds.Count < 3)
            _selectedHeroIds.Add(heroId);
    }

    private async Task StartMatchAsync()
    {
        if (CanStartMatch)
        {            
            await CombatService.StartEncounterCombatAsync(_selectedEncounterId!, _selectedHeroIds);
            NavManager.NavigateTo("/arena");
        }
    }
}
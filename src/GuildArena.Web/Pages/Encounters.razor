@page "/encounters"
@attribute [Authorize]
@using GuildArena.Shared.DTOs.GuildAndHeroes
@using GuildArena.Web.State
@inject HttpClient Http
@inject ICombatStateService CombatService
@inject NavigationManager NavManager

<PageTitle>World Encounters</PageTitle>

<div class="container mt-4 text-light">

    <div class="page-header">
        <h2 class="title text-danger">⚔️ Encounters</h2>
        <p class="subtitle">Select a bounty and prepare your team for combat.</p>
    </div>

    <!-- Simulação do Mapa/Lista de Missões -->
    <div class="card bg-dark border-danger mb-5 shadow">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h4 class="text-warning mb-0">Bandit Ambush</h4>
                <small class="text-light">Difficulty: ⭐</small>
            </div>
            <span class="badge bg-danger">Bounty Active</span>
        </div>
    </div>

    <!-- Secção de Preparação de Equipa (Drafting) -->
    <div class="page-header">
        <h4 class="title text-info">Draft Your Team</h4>
        <p class="subtitle">Select exactly 3 heroes to enter the Arena.</p>
    </div>

    @if (_heroes == null)
    {
        <p><em>Loading your roster...</em></p>
    }
    else
    {
        <div class="row">
            @foreach (var hero in _heroes)
            {
                var isSelected = _selectedHeroIds.Contains(hero.Id);
                <div class="col-md-3 col-sm-6 mb-3">
                    <div class="card @(isSelected ? "border-warning shadow" : "border-secondary") bg-dark text-center h-100"
                         style="cursor: pointer; transition: transform 0.2s;"
                         @onclick="() => ToggleSelection(hero.Id)">
                        <div class="card-body p-2">
                            <h6 class="card-title text-info mb-1">@hero.DefinitionId</h6>
                            <p class="card-text small text-light mb-0">Level @hero.CurrentLevel</p>
                            @if (isSelected)
                            {
                                <span class="badge bg-warning text-dark mt-2">Selected</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Barra Inferior de Ação -->
        <div class="text-center mt-4 border-top border-secondary pt-3">
            <h5 class="text-light mb-3">Team Size: <span class="text-warning">@_selectedHeroIds.Count</span> / 3</h5>
            <button class="btn btn-danger btn-lg fw-bold px-5"
                    disabled="@(_selectedHeroIds.Count != 3 || CombatService.IsConnecting)"
                    @onclick="StartMatchAsync">
                @(CombatService.IsConnecting ? "Entering Arena..." : "FIGHT!")
            </button>
        </div>
    }
</div>

@code {
    private List<HeroDto>? _heroes;
    private List<int> _selectedHeroIds = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _heroes = await Http.GetFromJsonAsync<List<HeroDto>>("api/guild/my-roster");
        }
        catch { }
    }

    private void ToggleSelection(int heroId)
    {
        if (_selectedHeroIds.Contains(heroId))
        {
            _selectedHeroIds.Remove(heroId);
        }
        else if (_selectedHeroIds.Count < 3)
        {
            _selectedHeroIds.Add(heroId);
        }
    }

    private async Task StartMatchAsync()
    {
        if (_selectedHeroIds.Count == 3)
        {
            await CombatService.StartPveCombatAsync("ENC_TUTORIAL_01", _selectedHeroIds);
            NavManager.NavigateTo("/arena");
        }
    }
}
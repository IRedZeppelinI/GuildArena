@page "/quests"
@attribute [Authorize]
@using GuildArena.Shared.DTOs.Quests
@inject HttpClient Http

<PageTitle>Daily Bounties</PageTitle>

<div class="container mt-4 text-light pb-5">

    <div class="page-header text-center mb-5">
        <h2 class="title text-warning fw-bold" style="font-family: 'Cinzel', serif;">📜 Daily Bounties</h2>
        <p class="subtitle text-light">Complete these tasks to earn gold and guild experience.</p>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger shadow-sm border-danger text-center">
            <h5 class="text-danger fw-bold mb-1">Notice</h5>
            <p class="mb-0">@_errorMessage</p>
        </div>
    }

    @if (_isLoading)
    {
        <p class="text-center mt-5"><em>Consulting the bounty board...</em></p>
    }
    else if (_quests == null || !_quests.Any())
    {
        <div class="text-center mt-5">
            <h4 class="text-muted">No bounties available.</h4>
            <p class="text-muted">Come back tomorrow for new tasks.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var quest in _quests)
            {
                // Proteção contra divisão por zero
                int target = quest.TargetValue > 0 ? quest.TargetValue : 1;
                // Impede que a barra passe dos 100% visualmente
                int progressPercent = (int)Math.Min(((double)quest.CurrentProgress / target) * 100, 100);

                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card bg-dark border-secondary h-100 shadow quest-card @(quest.IsCompleted ? "quest-completed" : "")">
                        <div class="card-body d-flex flex-column">

                            <!-- Header da Carta: Título e Botão de Reroll -->
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title text-info fw-bold mb-0" style="font-family: 'Cinzel', serif;">@quest.Name</h5>
                                @if (quest.IsCompleted)
                                {
                                    <span class="badge bg-success border border-light shadow-sm">Completed</span>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-warning reroll-btn"
                                            title="Reroll Quest (Once per day)"
                                            disabled="@_isRerolling"
                                            @onclick="() => RerollQuestAsync(quest.Id)">
                                        🎲
                                    </button>
                                }
                            </div>

                            <!-- Descrição -->
                            <p class="card-text small text-light mb-3 flex-grow-1">@quest.Description</p>
                            <!-- Recompensas -->
                            <div class="rewards-box bg-black p-2 rounded border border-dark mb-3 d-flex justify-content-around">
                                <div class="text-center" title="Gold Reward">
                                    <span class="fs-5 d-block">🪙</span>
                                    <span class="text-warning fw-bold small">@quest.RewardGold</span>
                                </div>
                                <div class="text-center border-start border-secondary ps-3" title="XP Reward">
                                    <span class="fs-5 d-block">⭐</span>
                                    <span class="text-info fw-bold small">@quest.RewardXP</span>
                                </div>
                            </div>

                            <!-- Barra de Progresso -->
                            <div class="progress-section mt-auto">
                                <div class="d-flex justify-content-between align-items-end mb-1">
                                    <span class="small text-light fw-bold">Progress</span>
                                    <span class="small @(quest.IsCompleted ? "text-success" : "text-warning") fw-bold">
                                        @(Math.Min(quest.CurrentProgress, target)) / @target
                                    </span>
                                </div>
                                <div class="progress border border-dark" style="height: 10px; background-color: #222;">
                                    <div class="progress-bar @(quest.IsCompleted ? "bg-success" : "bg-warning")"
                                         role="progressbar"
                                         style="width: @(progressPercent)%; transition: width 0.5s ease;">
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<QuestDto>? _quests;
    private bool _isLoading = true;
    private bool _isRerolling = false;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadQuestsAsync();
    }

    private async Task LoadQuestsAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            // Nota: Baseado no Controller gerado pelo DeepSeek com [Route("api/[controller]")]
            // Se o controller se chama QuestController, a rota será /api/quest
            _quests = await Http.GetFromJsonAsync<List<QuestDto>>("api/quest");

            // Ordenar para mostrar as incompletas primeiro
            if (_quests != null)
            {
                _quests = _quests.OrderBy(q => q.IsCompleted).ThenBy(q => q.Id).ToList();
            }
        }
        catch (Exception)
        {
            _errorMessage = "Failed to fetch quests from the server. Please try again later.";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RerollQuestAsync(int questId)
    {
        if (_isRerolling) return;

        _isRerolling = true;
        _errorMessage = null;

        try
        {
            var response = await Http.PostAsync($"api/quest/{questId}/reroll", null);

            if (response.IsSuccessStatusCode)
            {
                // Se re-rollou com sucesso, recarregamos a nova lista de quests
                await LoadQuestsAsync();
            }
            else
            {                
                _errorMessage = "Could not reroll the quest. You may have already used your daily reroll.";
            }
        }
        catch (Exception)
        {
            _errorMessage = "Connection error while trying to reroll.";
        }
        finally
        {
            _isRerolling = false;
        }
    }
}
@page "/register"
@using GuildArena.Shared.Requests
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>Register</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card bg-dark text-light border-secondary">
                <div class="card-header border-secondary text-center text-info">
                    <h4>Create Account</h4>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger p-2">@_errorMessage</div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Email Address</label>
                        <input type="email" class="form-control bg-secondary text-light" @bind="_request.Email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control bg-secondary text-light" @bind="_request.Password" />
                        <small class="text-muted">Minimum 6 characters, at least 1 number.</small>
                    </div>
                    <button class="btn btn-info w-100 fw-bold mt-3" @onclick="ExecuteRegister" disabled="@_isLoading">
                        @(_isLoading ? "Registering..." : "Sign Up")
                    </button>

                    <div class="mt-3 text-center">
                        <a href="/login" class="text-info text-decoration-none">Already have an account? Login here.</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginRequest _request = new() { Email = string.Empty, Password = string.Empty };
    private string? _errorMessage;
    private bool _isLoading;

    private async Task ExecuteRegister()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            // Endpoint padrão do Identity API
            var response = await Http.PostAsJsonAsync("register", _request);

            if (response.IsSuccessStatusCode)
            {
                // Registo com sucesso, mandamos para o Login
                NavManager.NavigateTo("/login");
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                _errorMessage = "Registration failed. Check password requirements.";
            }
        }
        catch
        {
            _errorMessage = "Connection error.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "GameData": {
    "RootFolder": "Data",
    "RacesFile": "races.json",
    "ModifiersFolder": "Modifiers",
    "CharactersFolder": "Characters",
    "AbilitiesFolder": "Abilities",
    "EncountersFolder": "Encounters",
    "DungeonsFolder": "Dungeons"
  },
  "IdentityOptions": {
    "Password": {
      "RequiredLength": 6,
      "RequireDigit": true,
      "RequireNonAlphanumeric": false,
      "RequireUppercase": false,
      "RequireLowercase": false
    },
    "User": {
      "RequireUniqueEmail": true
    }
  },
  "Email": {
    "FrontendBaseUrl": "https://localhost:7039/",
    "SenderName": "Guild Arena",
    "SenderEmail": "noreply@guildarena.xyz"
  }
}